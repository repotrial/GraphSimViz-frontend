{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "vite",
    "serve_dev": "vite --mode serve_dev",
    "build": "vite build",
    "lint": "eslint --ext .js,.vue src"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.3.0",
    "@fortawesome/free-regular-svg-icons": "^5.15.4",
    "@fortawesome/free-solid-svg-icons": "^5.15.4",
    "@fortawesome/vue-fontawesome": "^3.3.0",
    "@mdi/font": "^6.9.96",
    "axios": "^1.15.2",
    "material-design-icons-iconfont": "^6.7.0",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.9"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^9.33.0",
    "sass": "^1.101.0",
    "vite": "^8.1.3",
    "vite-plugin-vuetify": "^2.1.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "postcss": "^8.5.10",
    "uuid": "11.1.1"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "browser": true,
      "es2021": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
    },
    "rules": {
      "vue/valid-v-slot": [
        "error",
        {
          "allowModifiers": true
        }
      ],
      "vue/multi-word-component-names": "off"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
